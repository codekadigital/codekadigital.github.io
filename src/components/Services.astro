---
import { Icon } from 'astro-icon/components';
import { useTranslations, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="services" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-24 md:px-8 md:py-32">
  <p class="eyebrow mb-4" data-reveal>{t.services.eyebrow}</p>
  <h2 class="display-lg max-w-3xl text-ink" data-reveal="lines">{t.services.title}</h2>

  <div class="mt-12 grid gap-5 sm:grid-cols-2" data-reveal-group>
    {
      t.services.items.map(
        (item: { icon: string; title: string; copy: string }, i: number) => (
          <article class="card group p-7" data-reveal>
            <div class="flex items-start justify-between">
              <span class="grid h-11 w-11 place-items-center rounded-xl bg-accent-soft text-accent transition-transform duration-300 group-hover:scale-110">
                <Icon name={item.icon} class="h-5 w-5" />
              </span>
              <span class="pixel-label text-muted" aria-hidden="true">
                0{i + 1}
              </span>
            </div>
            <h3 class="display-md mt-5 text-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{item.copy}</p>
          </article>
        )
      )
    }
  </div>
</section>
