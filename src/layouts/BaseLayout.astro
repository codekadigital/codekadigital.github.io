---
import '../styles/global.css';
import { useTranslations, EMAIL, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const site = Astro.site!;
const canonical = new URL(lang === 'es' ? '/' : '/en/', site);
const ogImage = new URL('/og-image.png', site);

const jsonLdPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Karem Quiroz',
  alternateName: 'Codeka',
  jobTitle: 'AI Full Stack Web Developer',
  description: t.meta.description,
  url: site.toString(),
  image: ogImage.toString(),
  email: `mailto:${EMAIL}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Madrid',
    addressCountry: 'ES',
  },
  knowsAbout: [
    'AI Digital Product Development',
    'Full Stack Web Development',
    'Automation',
    'SEO',
  ],
  sameAs: ['https://github.com/codekadigital', 'https://www.linkedin.com/in/karem-quiroz/'],
};

const jsonLdWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Codeka — Karem Quiroz',
  url: site.toString(),
  inLanguage: lang === 'es' ? 'es-ES' : 'en-US',
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <meta name="author" content="Karem Quiroz" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    {/* hreflang es/en + x-default */}
    <link rel="alternate" hreflang="es" href={new URL('/', site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', site)} />

    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* favicons */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Codeka — Karem Quiroz" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.meta.ogAlt} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />

    {/* Twitter Cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={t.meta.ogAlt} />

    <meta name="theme-color" content="#0e0e12" />

    {/* JSON-LD */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdWebsite)} />

    {/* Tema antes del primer paint para evitar flash (dark por defecto) */}
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('codeka:theme') === 'light') {
            document.documentElement.dataset.theme = 'light';
          }
        } catch (e) {}
      })();
    </script>

    {/* Cadenas que necesita el JS global */}
    <script is:inline define:vars={{ konamiToast: t.konami.toast }}>
      document.documentElement.dataset.konamiToast = konamiToast;
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-[#0e0e12] focus:font-medium"
    >
      {t.nav.skipToContent}
    </a>

    <slot />

    <script>
      import { initMotion } from '../lib/motion';
      const konamiToast = document.documentElement.dataset.konamiToast || '🦴';
      initMotion({ konamiToast });
    </script>
  </body>
</html>
